<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Salesperson: See own routes -->
        <record id="rule_visit_route_salesman_see_own" model="ir.rule">
            <field name="name">Salesperson See Own Routes</field>
            <field name="model_id" ref="model_visit_route"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('sales_team.group_sale_salesman'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="0"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <!-- Salesperson: Create/Edit/Delete Own Draft Routes (Created by themselves) -->
        <record id="rule_visit_route_salesman_manage_own_draft" model="ir.rule">
            <field name="name">Salesperson Manage Own Draft Routes</field>
            <field name="model_id" ref="model_visit_route"/>
            <field name="domain_force">[('user_id', '=', user.id), ('state', '=', 'draft'), ('create_uid', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('sales_team.group_sale_salesman'))]"/>
            <field name="perm_read" eval="0"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>

        <!-- Manager: Full Access -->
        <record id="rule_visit_route_manager_all" model="ir.rule">
            <field name="name">Manager Full Access Routes</field>
            <field name="model_id" ref="model_visit_route"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('sales_team.group_sale_manager'))]"/>
        </record>

    </data>
</odoo>
