<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Record Rules for Visit Tracker Access Control -->
    
    <!-- Regular users can only see their own visits -->
    <record id="visit_tracker_rule_own_records" model="ir.rule">
        <field name="name">Visit Tracker: Own Records Only</field>
        <field name="model_id" ref="model_visit_tracker"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('sales_team.group_sale_salesman'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>
    <!-- Visit Report: Regular Salesmen see only own rows + unassigned (None) -->
    <record id="visit_report_rule_salesman_own" model="ir.rule">
        <field name="name">Visit Report: Salesman Own + Unassigned Only</field>
        <field name="model_id" ref="model_visit_report"/>
        <field name="domain_force">['|', ('user_id', '=', user.id), ('user_id', '=', False)]</field>
        <field name="groups" eval="[(4, ref('sales_team.group_sale_salesman'))]"/>
        <field name="perm_read" eval="True"/>
    </record>
    
    <!-- Visit Report: Salesmen with "See All Leads" access see everything -->
    <record id="visit_report_rule_salesman_all_leads" model="ir.rule">
        <field name="name">Visit Report: Salesman See All (All Leads Group)</field>
        <field name="model_id" ref="model_visit_report"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('sales_team.group_sale_salesman_all_leads'))]"/>
        <field name="perm_read" eval="True"/>
    </record>

    <!-- Visit Report: Managers see everything -->
    <record id="visit_report_rule_manager_all" model="ir.rule">
        <field name="name">Visit Report: Manager See All</field>
        <field name="model_id" ref="model_visit_report"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('sales_team.group_sale_manager'))]"/>
        <field name="perm_read" eval="True"/>
    </record>

<!-- </data></odoo> -->

    <!-- Sales Managers can see all visits -->
    <record id="visit_tracker_rule_manager_all" model="ir.rule">
        <field name="name">Visit Tracker: Managers See All</field>
        <field name="model_id" ref="model_visit_tracker"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('sales_team.group_sale_manager'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record id="visit_route_rule_own" model="ir.rule">
        <field name="name">Visit Route: Own Routes</field>
        <field name="model_id" ref="model_visit_route"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('sales_team.group_sale_salesman'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="visit_route_rule_manager_all" model="ir.rule">
        <field name="name">Visit Route: Managers Manage All</field>
        <field name="model_id" ref="model_visit_route"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('sales_team.group_sale_manager'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record id="visit_route_line_rule_own" model="ir.rule">
        <field name="name">Visit Route Stops: Own Routes</field>
        <field name="model_id" ref="model_visit_route_line"/>
        <field name="domain_force">[('route_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('sales_team.group_sale_salesman'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="visit_route_line_rule_own_manage_draft" model="ir.rule">
        <field name="name">Visit Route Stops: Own Draft Routes (Manage)</field>
        <field name="model_id" ref="model_visit_route_line"/>
        <field name="domain_force">[('route_id.user_id', '=', user.id), ('route_id.state', '=', 'draft')]</field>
        <field name="groups" eval="[(4, ref('sales_team.group_sale_salesman'))]"/>
        <field name="perm_read" eval="False"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record id="visit_route_line_rule_manager_all" model="ir.rule">
        <field name="name">Visit Route Stops: Managers Manage All</field>
        <field name="model_id" ref="model_visit_route_line"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('sales_team.group_sale_manager'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>
</odoo>
