<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Record Rules for Field Tracking Access Control -->

    <!-- Project users can only see their own check-ins -->
    <record id="visit_tracker_rule_own_records" model="ir.rule">
        <field name="name">Field Check-in: Own Records Only</field>
        <field name="model_id" ref="model_visit_tracker"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('project.group_project_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Project managers can see all check-ins -->
    <record id="visit_tracker_rule_manager_all" model="ir.rule">
        <field name="name">Field Check-in: Managers See All</field>
        <field name="model_id" ref="model_visit_tracker"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('project.group_project_manager'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- Visit Report: Project users see only their own rows -->
    <record id="visit_report_rule_user_own" model="ir.rule">
        <field name="name">Field Report: User Own + Unassigned Only</field>
        <field name="model_id" ref="model_visit_report"/>
        <field name="domain_force">['|', ('user_id', '=', user.id), ('user_id', '=', False)]</field>
        <field name="groups" eval="[(4, ref('project.group_project_user'))]"/>
        <field name="perm_read" eval="True"/>
    </record>

    <!-- Visit Report: Managers see everything -->
    <record id="visit_report_rule_manager_all" model="ir.rule">
        <field name="name">Field Report: Manager See All</field>
        <field name="model_id" ref="model_visit_report"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('project.group_project_manager'))]"/>
        <field name="perm_read" eval="True"/>
    </record>

    <!-- Route rules -->
    <record id="visit_route_rule_own" model="ir.rule">
        <field name="name">Field Route: Own Routes</field>
        <field name="model_id" ref="model_visit_route"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('project.group_project_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="visit_route_rule_manager_all" model="ir.rule">
        <field name="name">Field Route: Managers Manage All</field>
        <field name="model_id" ref="model_visit_route"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('project.group_project_manager'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record id="visit_route_line_rule_own" model="ir.rule">
        <field name="name">Field Route Stops: Own Routes (Read)</field>
        <field name="model_id" ref="model_visit_route_line"/>
        <field name="domain_force">[('route_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('project.group_project_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="visit_route_line_rule_own_manage_draft" model="ir.rule">
        <field name="name">Field Route Stops: Own Draft Routes (Manage)</field>
        <field name="model_id" ref="model_visit_route_line"/>
        <field name="domain_force">[('route_id.user_id', '=', user.id), ('route_id.state', '=', 'draft')]</field>
        <field name="groups" eval="[(4, ref('project.group_project_user'))]"/>
        <field name="perm_read" eval="False"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record id="visit_route_line_rule_manager_all" model="ir.rule">
        <field name="name">Field Route Stops: Managers Manage All</field>
        <field name="model_id" ref="model_visit_route_line"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('project.group_project_manager'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>
</odoo>
