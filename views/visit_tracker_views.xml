<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Search View -->
    <record id="view_visit_tracker_search" model="ir.ui.view">
        <field name="name">visit.tracker.search</field>
        <field name="model">visit.tracker</field>
        <field name="arch" type="xml">
            <search string="Search Field Check-ins">
                <field name="project_id"/>
                <field name="user_id"/>
                <field name="location_address"/>
                <filter string="Checked In" name="checked_in" domain="[('state', '=', 'done')]"/>
                <filter string="Checked Out" name="checked_out" domain="[('state', '=', 'checked_out')]"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Cancellation Requested" name="cancellation_requested" domain="[('state', '=', 'cancellation_requested')]"/>
                <filter string="Cancelled" name="cancelled" domain="[('state', '=', 'cancelled')]"/>
                <separator/>
                <filter string="Today" name="today" domain="[('visit_date', '&gt;=', context_today().strftime('%Y-%m-%d')), ('visit_date', '&lt;', (context_today() + relativedelta(days=1)).strftime('%Y-%m-%d'))]"/>
                <filter string="This Week" name="this_week" domain="[('visit_date', '&gt;=', (context_today() - relativedelta(days=context_today().weekday())).strftime('%Y-%m-%d'))]"/>
                <filter string="This Month" name="this_month" domain="[('visit_date', '&gt;=', context_today().strftime('%Y-%m-01'))]"/>
                <separator/>
                <group>
                    <filter string="Project" name="group_project" context="{'group_by': 'project_id'}"/>
                    <filter string="Team Member" name="group_user" context="{'group_by': 'user_id'}"/>
                    <filter string="Check-in Date" name="group_date" context="{'group_by': 'visit_date:day'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_visit_tracker_form" model="ir.ui.view">
        <field name="name">visit.tracker.form</field>
        <field name="model">visit.tracker</field>
        <field name="arch" type="xml">
            <form string="Field Check-in">
                <header>
                    <button name="action_check_out" string="Check Out" type="object"
                            class="btn-primary" invisible="1"/>
                    <button name="action_request_cancellation" string="Request Cancellation" type="object"
                            class="btn-warning" invisible="state not in ('done', 'checked_out')"/>
                    <button name="action_approve_cancellation" string="Approve Cancellation" type="object"
                            class="btn-primary" groups="project.group_project_manager"
                            invisible="state != 'cancellation_requested'"/>
                    <button name="action_reject_cancellation" string="Reject Cancellation" type="object"
                            class="btn-secondary" groups="project.group_project_manager"
                            invisible="state != 'cancellation_requested'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,done,checked_out,cancellation_requested,cancelled"/>
                </header>
                <sheet>
                    <group>
                        <group string="Visit Information">
                            <field name="project_id"/>
                            <field name="user_id"/>
                            <field name="visit_date"/>
                            <field name="check_out_date"/>
                            <field name="duration_minutes"/>
                            <field name="route_line_id" readonly="1"/>
                            <field name="planned_duration_minutes" invisible="not route_line_id"/>
                            <field name="is_planned" widget="boolean_toggle" readonly="1" invisible="1"/>
                        </group>
                        <group string="Location">
                            <field name="latitude"/>
                            <field name="longitude"/>
                            <field name="location_address"/>
                            <field name="maps_url" widget="url" text="View Check-in on Map"/>
                            <separator string="Check-out Location"/>
                            <field name="check_out_latitude"/>
                            <field name="check_out_longitude"/>
                            <field name="check_out_location_address"/>
                            <field name="check_out_maps_url" widget="url" text="View Check-out on Map"/>
                            <field name="device_info"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1" placeholder="Add visit notes here..."/>
                    </group>
                    <group string="Cancellation" invisible="state not in ('done', 'checked_out', 'cancellation_requested', 'cancelled')">
                        <group>
                            <field name="cancellation_reason" placeholder="Optional: add a reason before requesting cancellation"
                                   readonly="state not in ('done', 'checked_out')"/>
                            <field name="cancellation_request_date" readonly="1" invisible="state in ('done', 'checked_out')"/>
                        </group>
                        <group invisible="state in ('done', 'checked_out')">
                            <field name="cancelled_by_id" readonly="1" invisible="state != 'cancelled'"/>
                            <field name="rejection_reason" invisible="state not in ('cancellation_requested', 'done', 'checked_out')"
                                   placeholder="Optional reason when rejecting..."
                                   readonly="state in ('done', 'checked_out')"/>
                        </group>
                    </group>
                    <div class="o_visit_geolocation_control" invisible="state not in ('draft', 'done')">
                        <widget name="visit_geolocation_button"/>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="view_visit_tracker_tree" model="ir.ui.view">
        <field name="name">visit.tracker.tree</field>
        <field name="model">visit.tracker</field>
        <field name="arch" type="xml">
            <list string="Field Check-ins" default_order="visit_date desc">
                <field name="visit_date"/>
                <field name="check_out_date" optional="hide"/>
                <field name="user_id"/>
                <field name="project_id" optional="show"/>
                <field name="location_address" optional="show"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'checked_out'"
                       decoration-bf="state == 'done'"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'cancellation_requested'"
                       decoration-muted="state == 'cancelled'"/>
                <field name="maps_url" widget="url" text="Map" optional="show"/>
                <field name="duration_minutes" optional="hide"/>
                <field name="latitude" optional="hide"/>
                <field name="longitude" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Pivot View -->
    <record id="view_visit_tracker_pivot" model="ir.ui.view">
        <field name="name">visit.tracker.pivot</field>
        <field name="model">visit.tracker</field>
        <field name="arch" type="xml">
            <pivot string="Check-in Analysis" sample="1">
                <field name="user_id" type="row"/>
                <field name="visit_date" type="col" interval="day"/>
            </pivot>
        </field>
    </record>

    <!-- Graph View -->
    <record id="view_visit_tracker_graph" model="ir.ui.view">
        <field name="name">visit.tracker.graph</field>
        <field name="model">visit.tracker</field>
        <field name="arch" type="xml">
            <graph string="Check-in Statistics" type="bar" sample="1">
                <field name="user_id"/>
            </graph>
        </field>
    </record>

    <!-- Main Action -->
    <record id="action_visit_tracker" model="ir.actions.act_window">
        <field name="name">Field Check-ins</field>
        <field name="res_model">visit.tracker</field>
        <field name="view_mode">list,form,pivot,graph</field>
        <field name="search_view_id" ref="view_visit_tracker_search"/>
        <field name="context">{'search_default_checked_in': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Record your first field check-in!
            </p>
            <p>
                Track your team's location and check-ins at project sites.
            </p>
        </field>
    </record>

    <!-- Cancellation Requests (for project managers) -->
    <record id="action_visit_tracker_cancellation_requests" model="ir.actions.act_window">
        <field name="name">Cancellation Requests</field>
        <field name="res_model">visit.tracker</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_visit_tracker_search"/>
        <field name="context">{'search_default_cancellation_requested': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_empty_folder">
                No pending cancellation requests.
            </p>
            <p>
                Check-ins for which a team member has requested cancellation appear here.
            </p>
        </field>
    </record>

    <!-- Report Action -->
    <record id="action_visit_tracker_report" model="ir.actions.act_window">
        <field name="name">Check-in Reports</field>
        <field name="res_model">visit.tracker</field>
        <field name="view_mode">graph,pivot,list</field>
        <field name="search_view_id" ref="view_visit_tracker_search"/>
        <field name="context">{'search_default_checked_in': 1, 'search_default_group_user': 1}</field>
    </record>
</odoo>
