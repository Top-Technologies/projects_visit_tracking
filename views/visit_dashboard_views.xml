<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Dashboard Client Action -->
    <record id="action_visit_map_dashboard" model="ir.actions.client">
        <field name="name">Visit Map Dashboard</field>
        <field name="tag">sales_visit_tracking.visit_map_dashboard</field>
    </record>

    <!-- Main Menu under CRM -->
    <menuitem id="menu_visit_tracking_main"
              name="Visit Tracking"
              parent="crm.crm_menu_root"
              sequence="50"/>

    <menuitem id="menu_visit_dashboard"
              name="Map Dashboard"
              parent="menu_visit_tracking_main"
              action="action_visit_map_dashboard"
              sequence="5"/>

    <menuitem id="menu_visit_list"
              name="Visits"
              parent="menu_visit_tracking_main"
              action="action_visit_tracker"
              sequence="10"/>

    <menuitem id="menu_visit_cancellation_requests"
              name="Cancellation Requests"
              parent="menu_visit_tracking_main"
              action="action_visit_tracker_cancellation_requests"
              sequence="15"
              groups="sales_team.group_sale_manager"/>

    <menuitem id="menu_visit_report"
              name="Reports"
              parent="menu_visit_tracking_main"
              sequence="20"/>

    <menuitem id="menu_visit_report_analysis"
              name="Visit Analysis"
              parent="menu_visit_report"
              action="action_visit_report"
              sequence="10"/>
</odoo>
