<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Map Dashboard Client Action -->
    <record id="action_visit_map_dashboard" model="ir.actions.client">
        <field name="name">Field Team Map</field>
        <field name="tag">projects_visit_tracking.visit_map_dashboard</field>
    </record>

    <!-- Main sub-menu under Project app -->
    <menuitem id="menu_field_tracking_main"
              name="Field Tracking"
              parent="project.menu_main_pm"
              sequence="50"/>

    <menuitem id="menu_visit_dashboard"
              name="Live Map"
              parent="menu_field_tracking_main"
              action="action_visit_map_dashboard"
              sequence="5"/>

    <menuitem id="menu_visit_list"
              name="Check-ins"
              parent="menu_field_tracking_main"
              action="action_visit_tracker"
              sequence="10"/>

    <menuitem id="menu_visit_cancellation_requests"
              name="Cancellation Requests"
              parent="menu_field_tracking_main"
              action="action_visit_tracker_cancellation_requests"
              sequence="15"
              groups="project.group_project_manager"/>

    <menuitem id="menu_visit_report"
              name="Reports"
              parent="menu_field_tracking_main"
              sequence="20"/>

    <menuitem id="menu_visit_report_analysis"
              name="Visit Analysis"
              parent="menu_visit_report"
              action="action_visit_report"
              sequence="10"/>
</odoo>
