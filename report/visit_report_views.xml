<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Search View -->
    <record id="view_visit_report_search" model="ir.ui.view">
        <field name="name">visit.report.search</field>
        <field name="model">visit.report</field>
        <field name="arch" type="xml">
            <search string="Search Visit Reports">
                <field name="user_id"/>
                <field name="lead_id"/>
                <field name="partner_id"/>
                <field name="team_id"/>
                <filter string="Today" name="today" 
                        domain="[('report_date', '=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter string="This Week" name="this_week" 
                        domain="[('report_date', '&gt;=', (context_today() - relativedelta(days=context_today().weekday())).strftime('%Y-%m-%d'))]"/>
                <filter string="This Month" name="this_month" 
                        domain="[('report_date', '&gt;=', context_today().strftime('%Y-%m-01'))]"/>
                <separator/>
                <filter string="Over Target" name="over_target"
                        domain="[('visit_completion_rate', '&gt;=', 100)]"/>
                <filter string="Under Target" name="under_target"
                        domain="[('visit_completion_rate', '&lt;', 100), ('planned_visits', '&gt;', 0)]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Salesperson" name="group_user" context="{'group_by': 'user_id'}"/>
                    <filter string="Sales Team" name="group_team" context="{'group_by': 'team_id'}"/>
                    <filter string="Lead" name="group_lead" context="{'group_by': 'lead_id'}"/>
                    <filter string="Customer" name="group_partner" context="{'group_by': 'partner_id'}"/>
                    <filter string="Date" name="group_date" context="{'group_by': 'report_date:day'}"/>
                    <filter string="Week" name="group_week" context="{'group_by': 'report_date:week'}"/>
                    <filter string="Month" name="group_month" context="{'group_by': 'report_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- List View -->
    <record id="view_visit_report_tree" model="ir.ui.view">
        <field name="name">visit.report.tree</field>
        <field name="model">visit.report</field>
        <field name="arch" type="xml">
            <list string="Visit Analysis" create="0" edit="0" delete="0">
                <field name="report_date"/>
                <field name="user_id"/>
                <field name="lead_id" optional="show"/>
                <field name="partner_id" optional="hide"/>
                <field name="planned_visits" sum="Total Planned"/>
                <field name="actual_visits" sum="Total Actual"/>
                <field name="visit_variance" decoration-success="visit_variance &gt;= 0" decoration-danger="visit_variance &lt; 0"/>
                <field name="visit_completion_rate" widget="progressbar"/>
                <field name="planned_duration" sum="Total Planned Duration" optional="hide"/>
                <field name="actual_duration" sum="Total Actual Duration" optional="hide"/>
                <field name="duration_variance" decoration-success="duration_variance &lt;= 0" decoration-warning="duration_variance &gt; 0" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Pivot View -->
    <record id="view_visit_report_pivot" model="ir.ui.view">
        <field name="name">visit.report.pivot</field>
        <field name="model">visit.report</field>
        <field name="arch" type="xml">
            <pivot string="Visit Analysis" sample="1">
                <field name="user_id" type="row"/>
                <field name="report_date" type="col" interval="week"/>
                <field name="planned_visits" type="measure"/>
                <field name="actual_visits" type="measure"/>
                <field name="planned_duration" type="measure"/>
                <field name="actual_duration" type="measure"/>
                <field name="lead_count" type="measure"/>
                <field name="opportunity_count" type="measure"/>
                <field name="won_count" type="measure"/>
                <field name="lead_to_opportunity_rate" type="measure"/>
                <field name="opportunity_to_won_rate" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Graph View -->
    <record id="view_visit_report_graph" model="ir.ui.view">
        <field name="name">visit.report.graph</field>
        <field name="model">visit.report</field>
        <field name="arch" type="xml">
            <graph string="Visit Analysis" type="bar" sample="1">
                <field name="user_id"/>
                <field name="actual_visits" type="measure"/>
                <field name="planned_visits" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- Action -->
    <record id="action_visit_report" model="ir.actions.act_window">
        <field name="name">Planned vs Actual</field>
        <field name="res_model">visit.report</field>
        <field name="view_mode">pivot,graph,list</field>
        <field name="search_view_id" ref="view_visit_report_search"/>
        <field name="context">{'search_default_this_month': 1, 'search_default_group_user': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No visit data to analyze yet.
            </p>
            <p>
                This report compares planned route visits with actual check-ins to help analyze salesperson performance.
            </p>
        </field>
    </record>
</odoo>
