<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <!-- Template for CRM Lead Check-in Button -->
    <t t-name="sales_visit_tracking.LeadGeolocationButton" owl="1">
        <button type="button" class="btn btn-primary" t-on-click="onClickCheckIn">
            <i class="fa fa-map-marker me-1"/>Check In
        </button>
    </t>

    <!-- Template for Visit Tracker Check-in Button (backward compatibility) -->
    <t t-name="sales_visit_tracking.VisitGeolocationButton" owl="1">
        <div class="o_visit_geolocation_button">
            <button type="button" class="btn btn-primary" t-on-click="onClickCheckIn">
                <i class="fa fa-map-marker me-1"/>Check In
            </button>
        </div>
    </t>
</templates>
